#!/bin/busybox sh

# Mount essential filesystems
/bin/busybox mount -t proc none /proc
/bin/busybox mount -t sysfs none /sys
/bin/busybox mount -t devtmpfs none /dev

# Prepare devpts for proper PTY/TTY handling (job control)
/bin/busybox mkdir -p /dev/pts
/bin/busybox mount -t devpts devpts /dev/pts 2>/dev/null || echo "[warn] devpts mount failed"

# Create necessary device nodes if devtmpfs is not available
[ -c /dev/console ] || /bin/busybox mknod /dev/console c 5 1
[ -c /dev/null ] || /bin/busybox mknod /dev/null c 1 3
[ -c /dev/tty ] || /bin/busybox mknod /dev/tty c 5 0

# Set up busybox symlinks (suppress errors for missing /usr directories)
/bin/busybox --install -s

# Set hostname
hostname -F /etc/hostname 2>/dev/null || hostname localhost

# Configure loopback interface
ip link set lo up 2>/dev/null || ifconfig lo up

# Detect which console to use (prefer the kernel's console= parameter)
CONSOLE_DEV="/dev/console"
ACTIVE=$(cat /sys/class/tty/console/active 2>/dev/null)
if [ -n "$ACTIVE" ]; then
  # Use the last active console (the primary one the kernel selected)
  for c in $ACTIVE; do CONSOLE_DEV="/dev/$c"; done
fi

# Explicitly redirect all output to the console
exec <${CONSOLE_DEV} >${CONSOLE_DEV} 2>&1

# Clear screen and show boot message
clear
echo "Welcome to minimal kernel"
echo "Console device: ${CONSOLE_DEV}"
echo

# Respawn login on exit/timeout so PID 1 never dies
while true; do
  setsid cttyhack login
  echo ""
  echo "Login exited, restarting..."
  sleep 1
done