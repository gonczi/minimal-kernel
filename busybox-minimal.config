# Minimal static BusyBox configuration for initramfs
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_BUSYBOX=y
CONFIG_STATIC=y
CONFIG_FEATURE_SYSLOG=y
CONFIG_CROSS_COMPILER_PREFIX=""
CONFIG_INCLUDE_SUSv2=y
# Shell
CONFIG_SH_IS_ASH=y
CONFIG_BASH_IS_NONE=y
CONFIG_ASH=y
CONFIG_ASH_OPTIMIZE_FOR_SIZE=y
CONFIG_ASH_JOB_CONTROL=y
CONFIG_ASH_ALIAS=y
CONFIG_ASH_RANDOM_SUPPORT=y
CONFIG_ASH_EXPAND_PRMT=y
CONFIG_ASH_ECHO=y
CONFIG_ASH_PRINTF=y
CONFIG_ASH_TEST=y
CONFIG_CTTYHACK=y
# Core utilities
CONFIG_LS=y
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_MOUNT=y
CONFIG_MKNOD=y
CONFIG_MKDIR=y
CONFIG_RMDIR=y
CONFIG_RM=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_CLEAR=y
CONFIG_HOSTNAME=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_UNAME=y
CONFIG_DATE=y
CONFIG_SLEEP=y
CONFIG_TEST=y
CONFIG_TRUE=y
CONFIG_FALSE=y
CONFIG_STTY=y
CONFIG_TTY=y
CONFIG_PWD=y
# Networking (minimal)
CONFIG_IFCONFIG=y
# Disable heavy networking tools
# CONFIG_TC is not set
# CONFIG_IP is not set
# Misc
CONFIG_FEATURE_EDITING=y
CONFIG_FEATURE_TAB_COMPLETION=y
CONFIG_FEATURE_AUTOWIDTH=y
CONFIG_FEATURE_VERBOSE_USAGE=y
CONFIG_FEATURE_USE_TERMIOS=y
CONFIG_FEATURE_SEAMLESS_GZ=y
CONFIG_FEATURE_PRESERVE_HARDLINKS=y
CONFIG_FEATURE_COPYBUF_KB=4
# Password utilities (optional for login if shadow present)
CONFIG_PASSWD=y
CONFIG_SULOGIN=y
CONFIG_LOGIN=y
CONFIG_FEATURE_PASSWD_WEAK_CHECK=y
# Disable large/unused applets to keep size minimal
# (Most left unset intentionally)
